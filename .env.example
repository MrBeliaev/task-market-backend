# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskmarket?schema=public"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:5173"

# Indexer
POLLING_INTERVAL_MS=5000

# Admin access is verified on-chain via TaskMarket.isAdmin(address).
# No ADMIN_ADDRESS env var needed — admins are managed by the contract owner
# using addAdmin() / removeAdmin(). CONTRACT_ADDRESS below must point to the
# deployed contract so the backend can call isAdmin() for each admin request.
CONTRACT_ADDRESS="0x5FbDB2315678afecb367f032d93F642f64180aa3"
RPC_URL="http://127.0.0.1:8545"

# Telegram error alerts (optional)
# Create a bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
