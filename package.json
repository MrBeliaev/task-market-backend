{
  "name": "taskmarket-backend",
  "version": "1.0.0",
  "private": true,
  "description": "REST API and WebSocket server for TaskMarket: off-chain task metadata, EIP-191 auth, on-chain admin checks.",
  "author": "Pavel Beliaev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrBeliaev/task-market-backend.git"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx src/lib/seed.ts",
    "dependency:check": "./node_modules/.bin/madge --circular --warning --ts-config=./tsconfig.json --extensions ts --exclude ^generated/ src/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/multer": "^2.1.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "husky": "^9.1.7",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/madge": "^5.0.3",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1",
    "madge": "^8.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "@scarf/scarf@1.4.0": true,
    "prisma@7.8.0": true,
    "unrs-resolver@1.12.2": true,
    "esbuild@0.28.1": true
  }
}
